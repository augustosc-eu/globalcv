# -----------------------------------------------------------------------------
# GlobalCV Environment Variables
# Copy this file to `.env.local` and adjust values as needed.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Post Job Module (feature flag)
# Disabled by default. Set BOTH to true to enable UI + API submissions.
# -----------------------------------------------------------------------------
ENABLE_POST_JOB=false
NEXT_PUBLIC_ENABLE_POST_JOB=false

# -----------------------------------------------------------------------------
# Resend Email (used by /api/post-job when ENABLE_POST_JOB=true)
# Required only if post-job submissions are enabled.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM="GlobalCV Jobs <hello@augustosc.com>"

# -----------------------------------------------------------------------------
# Jobs Aggregator Source Controls
# -----------------------------------------------------------------------------

# Safe mode:
# - true (default behavior if omitted): stricter source set
# - false: allow broader source behavior (not recommended for public launch)
JOBS_SAFE_MODE=true
NEXT_PUBLIC_JOBS_SAFE_MODE=true

# Optional source toggles (safe defaults = false)
ENABLE_ARBEITNOW_SOURCE=false
NEXT_PUBLIC_ENABLE_ARBEITNOW_SOURCE=false

ENABLE_4DAYWEEK_SOURCE=false
NEXT_PUBLIC_ENABLE_4DAYWEEK_SOURCE=false

ENABLE_THEMUSE_SOURCE=false
NEXT_PUBLIC_ENABLE_THEMUSE_SOURCE=false

